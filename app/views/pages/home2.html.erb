<div class="cc-page">

  <!-- HERO -->
  <section class="cc-hero">
    <div class="cc-hero-content">
      <h1>Card Caster</h1>
      <h2>A shared tabletop for playing, creating, and experimenting with card games online.</h2>

      <p class="cc-hero-supporting">
        Move, flip, shuffle, and deal cards together in a live, interactive space —
        no rules locked in, no setup required.
      </p>

      <div class="cc-hero-cta">
        <%= link_to "Explore as Guest", "#", class: "btn btn-primary" %>
        <%= link_to "Join to play", "#", class: "btn btn-secondary" %>
        <%= link_to "How it works", "#", class: "btn btn-tertiary" %>
      </div>
    </div>

    <div class="cc-hero-visual">
      <!-- Placeholder animated tabletop -->
      <div class="card-stack">
        <div class="card"></div>
        <div class="card"></div>
        <div class="card"></div>
      </div>
    </div>
  </section>

  <!-- TEASER (PLACEHOLDER) -->
  <section class="cc-teaser">
    <p class="placeholder-text">
      Teaser section coming soon.
    </p>
  </section>

  <!-- SECTION 3 -->
  <section class="cc-usage">
    <header>
      <h2>How to use Card Caster</h2>
      <p class="cc-subheadline">
        Not a card game. A card game platform
      </p>
    </header>

    <div class="cc-usage-grid">
      <div class="cc-usage-item">
        <h3>Play together</h3>
        <p>
          Sit down at the same table with friends and interact with cards naturally —
          deal, draw, discard, and rearrange just like you would in person.
        </p>
      </div>

      <div class="cc-usage-item">
        <h3>Test and iterate</h3>
        <p>
          Try new game concepts, swap card designs on the fly, and see what works quickly.
          Explore ideas freely before committing time or money to physical prototypes.
        </p>
      </div>

      <div class="cc-usage-item">
        <h3>Discover and share</h3>
        <p>
          Invite others to watch, join in, or give feedback on new card ideas before they ever
          reach production. Get inspired by what other creators are building — and let your
          ideas spark new ones.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cc-final-cta">
    <h2>Ready to make the next card-game classic?</h2>
    <p>Join the Card Caster Community and start playtesting today!</p>

    <%= link_to "Start playing now!", "#", class: "btn btn-primary btn-large" %>
  </section>

</div>
