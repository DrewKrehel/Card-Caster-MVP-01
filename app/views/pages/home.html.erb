<header class="landing-hero-teaser" role="banner">
  <div class="container d-flex flex-wrap align-items-center justify-content-center gap-5">

    <!-- Hero Text -->
    <div class="landing-hero-text">
      <h1 class="landing-title">Card Caster</h1>
      <p class="landing-subtitle">
        A shared tabletop for playing, creating, and experimenting with card games online.
      </p>
      <p class="landing-supporting">
        Move, flip, shuffle, and deal cards together in a live, interactive space —
        no rules locked in, no setup required.
      </p>
      <div class="landing-ctas mt-3">
        <%= link_to "Explore as Guest", projects_path, class: "btn btn-primary btn-lg me-2" %>
        <%= link_to "Join to play", new_user_registration_path, class: "btn btn-outline-primary btn-lg me-2 join-btn" %>
        <a href="#how-it-works" class="btn btn-link btn-lg">How it works</a>
      </div>
    </div>

    <!-- Hero Image -->
    <div class="landing-teaser">
      <%= image_tag "landing_card_preview.png",
        alt: "Interactive card table preview",
        class: "img-fluid landing-teaser-image" %>
    </div>

  </div>
</header>

<main role="main">

  <!-- Teaser Cards Section -->
  <section class="landing-teaser" aria-labelledby="teaser-cards-heading">
    <div class="container text-center">
      <h2 id="teaser-cards-heading" class="visually-hidden">Card Caster Features</h2>

      <div class="teaser-cards">
        <% ["Easy to use", "Free to join", "Custom creations", "Play prototypes", "Give feedback"].each do |label| %>
          <article class="teaser-card js-rotatable-card" data-rotation="0" role="group" aria-label="<%= label %>">
            <div class="card-inner">
              <div class="card-face card-back"></div>
              <div class="card-face card-front">
                <span><%= label %></span>
              </div>
            </div>
          </article>
        <% end %>
      </div>

      <button id="teaserShuffle" class="btn btn-outline-secondary mt-4">
        Shuffle cards
      </button>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="landing-how" id="how-it-works" aria-labelledby="how-it-works-heading">
    <div class="container">

      <header class="text-center mb-5">
        <h2 id="how-it-works-heading">How to use Card Caster</h2>
        <p class="landing-how-subtitle">
          Not a card game. A card game platform.
        </p>
      </header>

      <div class="row g-5">

        <article class="col-md-4 text-center">
          <%= image_tag "landing_join_session.png",
            alt: "Play together",
            class: "img-fluid mb-3 landing-feature-image" %>
          <h3>Play together</h3>
          <p>
            Sit down at the same table with friends and interact with cards naturally —
            deal, draw, discard, and rearrange just like you would in person.
          </p>
        </article>

        <article class="col-md-4 text-center">
          <%= image_tag "landing_create_project.png",
            alt: "Test and iterate",
            class: "img-fluid mb-3 landing-feature-image" %>
          <h3>Test and iterate</h3>
          <p>
            Try new game concepts, swap card designs on the fly, and see what works quickly.
            Explore ideas freely before committing time or money to physical prototypes.
          </p>
        </article>

        <article class="col-md-4 text-center">
          <%= image_tag "landing_card_preview.png",
            alt: "Discover and share",
            class: "img-fluid mb-3 landing-feature-image" %>
          <h3>Discover and share</h3>
          <p>
            Invite others to watch, join in, or give feedback on new card ideas before they
            ever reach production. Get inspired by what other creators are building —
            and let your ideas spark new ones.
          </p>
        </article>

      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="landing-final-cta text-center" aria-labelledby="final-cta-heading">
    <div class="container">
      <h2 id="final-cta-heading">Ready to make the next card-game classic?</h2>
      <p>
        Join the Card Caster Community and start playtesting today!
      </p>

      <%= link_to "Start playing now!",
        new_user_registration_path,
        class: "btn btn-light btn-lg" %>
    </div>
  </section>

  <a href="https://storyset.com/leisure">Leisure illustrations by Storyset</a>

</main>
