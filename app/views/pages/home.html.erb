<div class="landing-hero">
  <div class="container text-center">
    <h1 class="landing-title">Card Caster</h1>

    <p class="landing-subtitle">
      A shared tabletop for playing, creating, and experimenting with card games online.
    </p>

    <p class="landing-supporting">
      Move, flip, shuffle, and deal cards together in a live, interactive space —
      no rules locked in, no setup required.
    </p>

    <div class="landing-ctas">
      <%= link_to "Explore as Guest", projects_path, class: "btn btn-primary btn-lg me-2" %>
      <%= link_to "Join to play", new_user_registration_path, class: "btn btn-outline-primary btn-lg me-2" %>
      <a href="#how-it-works" class="btn btn-link btn-lg">How it works</a>
    </div>
  </div>
</div>

<div class="landing-teaser">
  <div class="container text-center">
    <%= image_tag "landing_card_preview.png",
      alt: "Interactive card table preview",
      class: "img-fluid landing-teaser-image" %>
  </div>
</div>

<a id="how-it-works"></a>

<div class="landing-how">
  <div class="container">
    <div class="text-center mb-5">
      <h2>How to use Card Caster</h2>
      <p class="landing-how-subtitle">
        Not a card game. A card game platform.
      </p>
    </div>

    <div class="row g-5">
      <div class="col-md-4 text-center">
        <%= image_tag "landing_join_session.png",
          alt: "Play together",
          class: "img-fluid mb-3 landing-feature-image" %>

        <h5>Play together</h5>
        <p>
          Sit down at the same table with friends and interact with cards naturally —
          deal, draw, discard, and rearrange just like you would in person.
        </p>
      </div>

      <div class="col-md-4 text-center">
        <%= image_tag "landing_create_project.png",
          alt: "Test and iterate",
          class: "img-fluid mb-3 landing-feature-image" %>

        <h5>Test and iterate</h5>
        <p>
          Try new game concepts, swap card designs on the fly, and see what works quickly.
          Explore ideas freely before committing time or money to physical prototypes.
        </p>
      </div>

      <div class="col-md-4 text-center">
        <%= image_tag "landing_card_preview.png",
          alt: "Discover and share",
          class: "img-fluid mb-3 landing-feature-image" %>

        <h5>Discover and share</h5>
        <p>
          Invite others to watch, join in, or give feedback on new card ideas before they
          ever reach production. Get inspired by what other creators are building —
          and let your ideas spark new ones.
        </p>
      </div>
    </div>
  </div>
</div>

<div class="landing-final-cta">
  <div class="container text-center">
    <h2>Ready to make the next card-game classic?</h2>
    <p>
      Join the Card Caster Community and start playtesting today!
    </p>

    <%= link_to "Start playing now!",
      new_user_registration_path,
      class: "btn btn-light btn-lg" %>
  </div>
</div>
