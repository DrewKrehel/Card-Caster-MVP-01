<div id="<%= dom_id project %>">
  <p>
    <strong>Creator:</strong>
    <%= project.creator.username %>
  </p>

  <p>
    <strong>Name:</strong>
    <%= project.name %>
  </p>

  <p>
    <strong>Summary:</strong>
    <%= project.summary %>
  </p>

  <p>
    <strong>How to play:</strong>
    <%= project.how_to_play %>
  </p>

  <p>
    <strong>Max players:</strong>
    <%= project.max_players %>
  </p>

  <p>
    <strong>Image:</strong>
    <%= image_tag(
      project.image? ? project.image_url : "placeholder.jpg"
    ) %>
  </p>

  <p>
    <strong>Private:</strong>
    <%= project.private %>
  </p>

  <% if user_signed_in? %>
    <%= form_with(model: GameSession.new, url: game_sessions_path, local: true) do |f| %>
      <%= f.hidden_field :project_id, value: project.id %>
      <%= f.hidden_field :owner_id, value: current_user.id %>

      <div class="mb-2">
        <%= f.label :name, "Session Name" %>
        <%= f.text_field :name, required: true, class: "form-control", placeholder: "Enter session name" %>
      </div>

      <%= f.submit "Start Game Session", class: "btn btn-primary" %>
    <% end %>
  <% else %>
    <%= link_to "Sign in to start a session",
        new_user_session_path,
        class: "btn btn-outline-secondary" %>
  <% end %>

  <h2 class="mt-4">Active Game Sessions</h2>

  <% if @game_sessions.any? %>
    <ul class="list-group">
      <% @game_sessions.each do |session| %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <div>
            <strong><%= session.name %></strong>
            <small class="text-muted">— Host: <%= session.owner.username %></small>
          </div>

          <div class="d-flex gap-2">
            <% session_user = session.session_users.find_by(user: current_user) %>

            <% if session_user.present? %>
              <!-- Already joined (any role) -->
              <%= link_to "Enter Session",
                        game_session_path(session),
                        class: "btn btn-sm btn-success" %>

              <span class="badge bg-secondary text-uppercase">
                <%= session_user.role %>
              </span>
            <% else %>
              <!-- Join as player -->
              <%= button_to "Join as Player",
                          join_as_player_game_session_path(session),
                          method: :post,
                          class: "btn btn-sm btn-primary" %>

              <!-- Join as observer -->
              <%= button_to "Join as Observer",
                          join_as_observer_game_session_path(session),
                          method: :post,
                          class: "btn btn-sm btn-outline-secondary" %>
            <% end %>

            <!-- Delete button (owner only) -->
            <% if session.owner == current_user %>
              <%= button_to "Delete",
                          game_session_path(session),
                          method: :delete,
                          data: { confirm: "Delete this session?" },
                          class: "btn btn-sm btn-danger" %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-muted">No active sessions yet.</p>
  <% end %>

</div>
