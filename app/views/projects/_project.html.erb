<div class="container my-5">

  <div id="<%= dom_id project %>" class="row justify-content-center">
    <div class="col-lg-10">

      <!-- Project Header -->
      <div class="mb-5">

        <!-- Image -->
        <div class="mb-4 text-center">
          <%= image_tag(
          project.image? ? project.image_url : "placeholder.jpg",
          class: "img-fluid rounded-4 shadow-sm project-detail-image",
          alt: project.name
        ) %>
        </div>

        <!-- Title -->
        <h1 class="fw-bold mb-3"><%= project.name %></h1>

        <!-- Creator + Meta -->
        <div class="d-flex flex-wrap align-items-center gap-3 mb-3">

          <!-- Creator -->
          <div class="d-flex align-items-center">
            <%= image_tag project.creator.profile_image,
            class: "rounded-circle me-2",
            width: 36,
            height: 36 %>

            <span class="fw-semibold">
              <%= project.creator.username %>
            </span>
          </div>

          <!-- Max Players Badge -->
          <span class="badge bg-light text-dark border px-3 py-2">
            👥 Max Players: <%= project.max_players %>
          </span>

        </div>

        <!-- Summary -->
        <p class="lead text-muted">
          <%= project.summary %>
        </p>

      </div>

      <hr class="my-5">

      <!-- Project Details Section -->
      <div class="row mb-5">

        <div class="col-md-8">
          <h4 class="fw-semibold mb-3">How to Play</h4>
          <p><%= project.how_to_play %></p>
        </div>

      </div>

      <hr class="my-5">

      <!-- Session Creation -->
      <div class="mb-5">

        <h2 class="fw-semibold mb-3">Start a Game Session</h2>

        <% if user_signed_in? %>

          <%= form_with(model: GameSession.new,
                        url: game_sessions_path,
                        local: true,
                        class: "row g-3 align-items-end") do |f| %>

            <%= f.hidden_field :project_id, value: project.id %>
            <%= f.hidden_field :owner_id, value: current_user.id %>

            <div class="col-md-8">
              <%#= f.label :name, "Session Name", class: "form-label" %>
              <%= f.text_field :name,
                    class: "form-control",
                    placeholder: "Enter session name" %>
            </div>

            <div class="col-md-4">
              <%= f.submit "Start Session",
                    class: "btn btn-primary w-100" %>
            </div>

          <% end %>

        <% else %>

          <%= link_to "Sign in to start a session",
                new_user_session_path,
                class: "btn btn-outline-secondary" %>

        <% end %>

      </div>

      <hr class="my-5">

      <!-- Active Sessions -->
      <div>
        <!--<h4 class="fw-semibold mb-4">Active Sessions</h4>-->

        <%= render "game_sessions/list",
              game_sessions: project.game_sessions.includes(:owner, :session_users) %>
      </div>

    </div>
  </div>

</div>
