<div class="row mb-4">
  <div class="col-md-6 offset-md-3">
    <div class="card">
      <%= image_tag(
      project.image? ? project.image_url : "placeholder.jpg", class: "card-img-top"
    ) %>
      <%#= image_tag project.image_url, class: "card-img-top" %>
      <div class="card-body">
        <div class="flex-shrink-0">
          <%= image_tag project.creator.avatar_image, class: "rounded-circle me-2", width: "36px", alt: "#{project.creator.username}'s avatar" %>
        </div>
        <h5 class="card-title"><%= project.creator.username %></h5>
        <p class="card-text"><%= project.summary %></p>
      </div>
      <ul class="list-group list-group-flush">
        <li class="list-group-item">Comment</li>
      </ul>
      <div class="card-body">
        <%= link_to "Show this project", project %>
        <a href="#" class="card-link">Another link</a>
      </div>
    </div>
  </div>
</div>
