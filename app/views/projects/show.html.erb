<div class="container my-5">

  <!-- Project Content -->
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <%= render @project %>
    </div>
  </div>

  <!-- Action Bar -->
  <div class="row justify-content-center mt-4">
    <div class="col-lg-8">

      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 p-4 bg-light rounded-4 shadow-sm">

        <!-- Left side: Back -->
        <div>
          <%= link_to "← Back to projects",
                projects_path,
                class: "btn btn-outline-secondary" %>
        </div>

        <!-- Right side: Owner Actions -->
        <% if user_signed_in? && current_user == @project.creator %>
          <div class="d-flex align-items-center gap-2">

            <%= link_to "Edit",
                  edit_project_path(@project),
                  class: "btn btn-outline-primary" %>

            <%= button_to "Delete",
                  @project,
                  method: :delete,
                  data: { confirm: "Are you sure?" },
                  class: "btn btn-outline-danger" %>

          </div>
        <% end %>

      </div>

    </div>
  </div>

</div>

