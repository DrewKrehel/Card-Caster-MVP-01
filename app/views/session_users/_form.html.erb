<%= form_with(model: session_user) do |form| %>
  <% if session_user.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(session_user.errors.count, "error") %> prohibited this session_user from being saved:</h2>

      <ul>
        <% session_user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :session_id, style: "display: block" %>
    <%= form.text_field :session_id %>
  </div>

  <div>
    <%= form.label :user_id, style: "display: block" %>
    <%= form.text_field :user_id %>
  </div>

  <div>
    <%= form.label :role, style: "display: block" %>
    <%= form.number_field :role %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
