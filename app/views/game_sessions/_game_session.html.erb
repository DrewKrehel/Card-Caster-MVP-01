<div id="<%= dom_id game_session %>">
  <p><strong>Project:</strong> <%= game_session.project.name %></p>
  <p><strong>Owner:</strong> <%= game_session.owner.username %></p>
  <p><strong>Name:</strong> <%= game_session.name %></p>
  <p><strong>Private:</strong> <%= game_session.private %></p>

  <hr>

  <h5><%= game_session.name %></h5>

  <% PlayingCard::ZONES.each do |zone| %>
    <h6 class="mt-4 d-flex align-items-center justify-content-between">
      <%= zone %>

      <!-- Shuffle button -->
      <%= button_to "Shuffle",
                  shuffle_game_session_zone_path(game_session, zone_name: zone),
                  method: :patch,
                  class: "btn btn-sm btn-outline-primary" %>
    </h6>

    <div class="zone-grid">
      <% game_session.playing_cards.in_zone(zone).ordered.each do |card| %>
        <div class="card-slot">
          <%= render "playing_cards/playing_card",
                 card: card,
                 current_zone: zone %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
