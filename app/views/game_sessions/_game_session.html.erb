<div id="<%= dom_id game_session %>">
  <p><strong>Project:</strong> <%= game_session.project.name %></p>
  <p><strong>Owner:</strong> <%= game_session.owner.username %></p>
  <p><strong>Name:</strong> <%= game_session.name %></p>
  <p><strong>Session ID:</strong> <%= game_session.id %></p>

  <hr>

  <h5><%= game_session.name %></h5>

  <!-- SessionUser represents the current user's role + zone inside this session -->
  <% session_user = game_session.session_users.find_by(user: current_user) %>

  <!-- Iterate through all defined zones (Deck, Neutral, Player 1, etc.) -->
  <% PlayingCard::ZONES.each do |zone| %>
    <h6 class="mt-4 d-flex align-items-center justify-content-between">
      <span>
        <%= zone %>
        <% if (zone_user = game_session.user_for_zone(zone)) %>
          <span class="badge bg-secondary ms-2"><%= zone_user.username %></span>
        <% end %>
        <% if zone_user == current_user %>
          <span class="badge bg-success ms-1">You</span>
        <% end %>
      </span>

      <%= button_to "Shuffle",
                  shuffle_game_session_zone_path(game_session, zone_name: zone),
                  method: :patch,
                  form: { data: { turbo_stream: true } },
                  class: "btn btn-sm btn-outline-primary" %>
    </h6>

    <div id="zone-grid-<%= zone %>" class="zone-grid">
      <% cards = game_session.playing_cards.in_zone(zone).ordered %>
      <% cards.each do |card| %>
        <div class="card-slot">
          <%= render "playing_cards/playing_card",
                   card: card,
                   current_zone: zone,
                   can_interact: session_user&.can_interact_with_zone?(zone) %>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
