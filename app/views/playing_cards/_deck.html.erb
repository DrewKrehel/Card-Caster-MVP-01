<div id="<%= dom_id(top_card) %>"
     class="playing-card"
     data-controller="card"
     data-card-rotation-value="0"
     data-action="click->card#rotate">

  <div class="card-inner">
    <div class="card-face card-back">
      <%= image_tag top_card.back_image_url, class: "card-image" %>
    </div>
  </div>

  <div class="card-controls">
    <div class="dropdown">
      <button class="btn btn-sm btn-dark dropdown-toggle" data-bs-toggle="dropdown">
        Draw
      </button>

      <ul class="dropdown-menu">
        <% PlayingCard::ZONES.each do |zone| %>
          <% next if zone == "Deck" %>
          <li>
            <%= button_to zone,
                  move_playing_card_path(top_card, zone_name: zone),
                  method: :patch,
                  form: { data: { turbo_stream: true } },
                  class: "dropdown-item" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
