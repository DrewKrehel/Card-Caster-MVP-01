<figure class="playing-card">

  <!-- Card Image -->
  <div class="card-frame">
    <%#= image_tag top_card.back_image_url, class: "card-image" %>
    <%= image_tag "ai-deck-01.png", class: "card-image", alt: "Card back" %>
  </div>

  <figcaption class="card-controls">

    <!-- Draw Dropdown -->
    <nav class="dropdown d-inline me-2" aria-label="Draw actions">
      <button class="btn btn-sm btn-dark dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
        Draw
      </button>
      <ul class="dropdown-menu">
        <% PlayingCard::ZONES.each do |zone| %>
          <% next if zone.in?(["Deck"]) %>
          <li>
            <%= button_to zone,
                          move_playing_card_path(top_card, zone_name: zone),
                          method: :patch,
                          class: "dropdown-item" %>
          </li>
        <% end %>
      </ul>
    </nav>

    <!-- Peek Action -->
    <div class="peek-wrapper d-inline" aria-label="Peek at card">
      <button class="btn btn-sm btn-outline-warning" aria-describedby="peek-popup-<%= top_card.id %>">
        👁 Peek
      </button>
      <div id="peek-popup-<%= top_card.id %>" class="peek-popup">
        <%= image_tag top_card.image_url, class: "peek-image", alt: "Card face" %>
      </div>
    </div>

  </figcaption>

</figure>
