<div class="playing-card">

  <div class="card-frame">
    <%#= image_tag top_card.back_image_url,
                  class: "card-image" %>
    <%= image_tag "ai-deck-01.png", class: "card-image" %>
  </div>

  <div class="card-controls">
    <!-- Draw -->
    <div class="dropdown">
      <button class="btn btn-sm btn-dark dropdown-toggle" data-bs-toggle="dropdown">
        Draw
      </button>

      <ul class="dropdown-menu">
        <% PlayingCard::ZONES.each do |zone| %>
          <% next if zone.in?(["Deck"]) %>
          <li>
            <%= button_to zone,
                          move_playing_card_path(top_card, zone_name: zone),
                          method: :patch,
                          class: "dropdown-item" %>
          </li>
        <% end %>
      </ul>
    </div>

    <!-- Peek -->
    <div class="peek-wrapper">
      <button class="btn btn-sm btn-outline-warning">👁 Peek</button>
      <div class="peek-popup">
        <%= image_tag top_card.image_url, class: "peek-image" %>
      </div>
    </div>
  </div>
</div>
