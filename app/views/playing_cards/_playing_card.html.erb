<div id="<%= dom_id(card) %>"
     class="playing-card <%= 'disabled-card' unless can_interact %>"
     data-controller="card"
     data-card-id-value="<%= card.id %>"
     data-card-rotation-value="<%= card.orientation_degrees %>"
     data-card-face-up-value="<%= card.face_up %>"
     data-action="<%= 'click->card#rotate' if can_interact %>">

  <div class="card-inner">
    <div class="card-face card-back">
      <%= image_tag card.back_image_url, class: "card-image" %>
    </div>

    <div class="card-face card-front">
      <%= image_tag card.image_url, class: "card-image" %>
    </div>
  </div>

  <% if can_interact %>
    <div class="card-controls">
      <!-- MOVE -->
      <div class="dropdown">
        <button class="btn btn-sm btn-dark dropdown-toggle" data-bs-toggle="dropdown">
          Move
        </button>

        <ul class="dropdown-menu">
          <% PlayingCard::ZONES.each do |zone| %>
            <% next if zone == current_zone %>
            <li>
              <%= button_to zone,
                    move_playing_card_path(card, zone_name: zone),
                    method: :patch,
                    form: { data: { turbo_stream: true } },
                    class: "dropdown-item" %>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- FLIP -->
      <button class="btn btn-sm btn-dark"
              data-action="click->card#flip">
        <%= card.face_up? ? "↓" : "↑" %>
      </button>
    </div>
  <% end %>
</div>
