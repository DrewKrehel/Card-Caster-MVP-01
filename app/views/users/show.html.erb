<div class="container mt-5">
  <!--Username-->
  <div class="d-flex align-items-center gap-3">

    <%= image_tag @user.profile_image,
              class: "rounded-circle me-2",
              width: "128",
              alt: "#{@user.username}'s profile image" %>

    <h1 class="display-4 mb-0"><%= @user.username %></h1>
  </div>

  <!--Bio-->
  <div class="row mb-3">
    <p class="lead"><%= @user.bio %></p>
  </div>
</div>

<ul class="nav nav-tabs mb-4" id="userTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active"
            id="projects-tab"
            data-bs-toggle="tab"
            data-bs-target="#projects"
            type="button"
            role="tab">
      Projects
    </button>
  </li>

  <li class="nav-item" role="presentation">
    <button class="nav-link"
            id="sessions-tab"
            data-bs-toggle="tab"
            data-bs-target="#sessions"
            type="button"
            role="tab">
      Active Game Sessions
    </button>
  </li>
</ul>

<div class="tab-content">
  <!-- Projects tab -->
  <div class="tab-pane fade show active"
       id="projects"
       role="tabpanel">

    <% if @owned_projects.any? %>
      <ul class="list-unstyled">
        <% @owned_projects.each do |project| %>
          <%= render "projects/preview", project: project %>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted">This user hasn’t created any projects yet.</p>
    <% end %>
  </div>

  <!-- Sessions tab -->
  <div class="tab-pane fade"
       id="sessions"
       role="tabpanel">

    <%= render "game_sessions/list",
          game_sessions: @active_game_sessions %>
  </div>
</div>
