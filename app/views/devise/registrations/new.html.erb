<main class="container py-5">
  <header class="mb-4 text-center">
    <h1 class="display-5">Sign Up</h1>
    <p class="text-muted">Create your Card Caster account</p>
  </header>

  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "needs-validation" }) do |f| %>

        <%= f.error_notification class: "alert alert-danger", role: "alert", aria_live: "assertive" %>
        
        <% if resource.errors.any? %>
          <aside class="alert alert-danger" role="alert">
            <h2 class="h6 alert-heading">
              <%= pluralize(resource.errors.count, "error") %> prevented this account from being created:
            </h2>
            <ul class="mb-0">
              <% resource.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </aside>
        <% end %>

        <fieldset>
          <legend class="visually-hidden">Account Information</legend>

          <div class="mb-3">
            <%= f.input :username,
                        required: true,
                        autofocus: true,
                        input_html: { 
                          class: "form-control", 
                          autocomplete: "username",
                          aria_required: "true",
                          maxlength: 30,
                          aria_describedby: "username-help"
                        } %>
            <small id="username-help" class="form-text text-muted">
              Maximum 30 characters. This will be your public display name.
            </small>
          </div>

          <div class="mb-3">
            <%= f.input :email,
                        required: true,
                        input_html: { 
                          class: "form-control", 
                          autocomplete: "email",
                          aria_required: "true",
                          aria_describedby: "email-help"
                        } %>
            <small id="email-help" class="form-text text-muted">
              We'll never share your email with anyone else.
            </small>
          </div>

          <div class="mb-3">
            <%= f.input :password,
                        required: true,
                        hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                        input_html: { 
                          class: "form-control", 
                          autocomplete: "new-password",
                          aria_required: "true",
                          minlength: @minimum_password_length
                        } %>
          </div>

          <div class="mb-3">
            <%= f.input :password_confirmation,
                        label: "Confirm Password",
                        required: true,
                        input_html: { 
                          class: "form-control", 
                          autocomplete: "new-password",
                          aria_required: "true"
                        } %>
          </div>

          <div class="mb-3">
            <%= f.input :bio,
                        as: :text,
                        required: false,
                        input_html: { 
                          class: "form-control",
                          rows: 3,
                          maxlength: 500,
                          aria_describedby: "bio-help"
                        },
                        hint: false %>
            <small id="bio-help" class="form-text text-muted">
              Optional. Maximum 500 characters. Tell others about yourself.
            </small>
          </div>

          <div class="mb-4">
            <%= f.label :avatar_image, "Profile Image (Optional)", class: "form-label" %>
            <%= f.file_field :avatar_image, 
                            class: "form-control",
                            accept: "image/*",
                            aria_describedby: "avatar-help" %>
            <small id="avatar-help" class="form-text text-muted">
              Upload a profile picture to personalize your account.
            </small>
          </div>

          <div class="d-grid mb-4">
            <%= f.button :submit, "Create Account", class: "btn btn-primary btn-lg" %>
          </div>
        </fieldset>
      <% end %>

      <footer class="text-center">
        <%= render "devise/shared/links" %>
      </footer>
    </div>
  </div>
</main>
