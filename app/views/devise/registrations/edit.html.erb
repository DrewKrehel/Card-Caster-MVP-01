<div class="container py-5">
  <h2 class="display-5 mb-4 text-center">Edit <%= resource_name.to_s.humanize %></h2>

  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "needs-validation" }) do |f| %>
        
        <%= f.error_notification class: "alert alert-danger" %>

        <div class="mb-3">
          <%= f.input :email, required: true, autofocus: true, input_html: { class: "form-control" } %>
        </div>

        <div class="mb-3">
          <%= f.input :username, required: true, input_html: { class: "form-control" } %>
        </div>

        <div class="mb-3">
          <%= f.label :avatar_image, "Profile Image", class: "form-label" %>
          <%= f.file_field :avatar_image, class: "form-control" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="alert alert-warning mb-3">
            Currently waiting confirmation for: <%= resource.unconfirmed_email %>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.input :password,
                      hint: "Leave it blank if you don't want to change it",
                      required: false,
                      input_html: { class: "form-control", autocomplete: "new-password" } %>
        </div>

        <div class="mb-3">
          <%= f.input :password_confirmation,
                      required: false,
                      input_html: { class: "form-control", autocomplete: "new-password" } %>
        </div>

        <div class="mb-3">
          <%= f.input :current_password,
                      hint: "We need your current password to confirm your changes",
                      required: true,
                      input_html: { class: "form-control", autocomplete: "current-password" } %>
        </div>

        <div class="d-grid mb-4">
          <%= f.button :submit, "Update", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>

      <hr>

      <h3 class="h5 text-danger mb-3">Cancel my account</h3>
      <p>Unhappy? You can cancel your account below:</p>
      <div class="d-grid">
        <%= button_to "Cancel my account",
                      registration_path(resource_name),
                      data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
                      method: :delete,
                      class: "btn btn-outline-danger btn-lg" %>
      </div>

      <div class="mt-4 text-center">
        <%= link_to "Back", :back, class: "btn btn-outline-secondary btn-lg" %>
      </div>
    </div>
  </div>
</div>
