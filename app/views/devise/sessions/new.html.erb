<main class="container py-5">
  <header class="mb-4 text-center">
    <h1 class="display-5">Log In</h1>
    <p class="text-muted">Welcome back to Card Caster</p>
  </header>

  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">
      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "needs-validation" }) do |f| %>
        
        <%= f.error_notification class: "alert alert-danger", role: "alert", aria_live: "assertive" %>

        <fieldset>
          <legend class="visually-hidden">Login Credentials</legend>

          <div class="mb-3">
            <%= f.input :email,
                        required: true,
                        autofocus: true,
                        label: "Email",
                        input_html: { 
                          class: "form-control",
                          autocomplete: "email",
                          aria_required: "true",
                          placeholder: "Enter your email"
                        } %>
          </div>

          <div class="mb-3">
            <%= f.input :password,
                        required: true,
                        label: "Password",
                        input_html: { 
                          class: "form-control",
                          autocomplete: "current-password",
                          aria_required: "true",
                          placeholder: "Enter your password"
                        } %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="mb-4">
              <div class="form-check">
                <%= f.input :remember_me, 
                            as: :boolean,
                            label: "Remember me",
                            input_html: { 
                              class: "form-check-input",
                              role: "switch"
                            },
                            wrapper_html: { class: "form-check" },
                            label_html: { class: "form-check-label" } %>
              </div>
            </div>
          <% end %>

          <div class="d-grid mb-4">
            <%= f.button :submit, "Log In", class: "btn btn-primary btn-lg" %>
          </div>
        </fieldset>
      <% end %>

      <hr aria-hidden="true" class="my-4">

      <footer class="text-center">
        <%= render "devise/shared/links" %>
      </footer>
    </div>
  </div>
</main>
